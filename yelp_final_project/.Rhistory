library(readr)
library(tidyverse)
# getting Philly Businesses and IDs
raw_biz <- read_csv("yelp_academic_dataset_business.csv")
philly_restaurants <- raw_biz %>%
filter(city == "Philadelphia") %>%
filter(str_detect(categories, "Restaurants"))
philly_ids <- philly_restaurants$business_id
write_csv(philly_restaurants, "philly_restaurants.csv")
print(paste("Found", length(philly_ids), "restaurants in Philadelphia."))
# load and filter check-ins (potentially slow step)
# Each row is a business, the 'date' column is a long string of timestamps
checkins <- read_csv("yelp_academic_dataset_checkin.csv") %>%
filter(business_id %in% philly_ids) %>%
separate_rows(date, sep = ", ") %>%
mutate(
date = as.POSIXct(date, format="%Y-%m-%d %H:%M:%S"),
day = wday(date, label = TRUE, abbr = FALSE),
hour = hour(date)
)
write_csv(checkins, "philly_checkins.csv")
